menu "XPT2046 SoftSPI"

    config CYD_TOUCH_ENABLED
        bool "Enable CYD XPT2046 touch controller"
        default y

    config CYD_TOUCH_PIN_SCLK
        int "CYD touch SCLK GPIO"
        default 25
        range -1 48
        depends on CYD_TOUCH_ENABLED

    config CYD_TOUCH_PIN_MOSI
        int "CYD touch MOSI GPIO"
        default 32
        range -1 48
        depends on CYD_TOUCH_ENABLED

    config CYD_TOUCH_PIN_MISO
        int "CYD touch MISO GPIO"
        default 39
        range -1 48
        depends on CYD_TOUCH_ENABLED

    config CYD_TOUCH_PIN_CS
        int "CYD touch CS GPIO"
        default 33
        range -1 48
        depends on CYD_TOUCH_ENABLED

    config CYD_TOUCH_PIN_INT
        int "CYD touch interrupt GPIO"
        default 36
        range -1 48
        depends on CYD_TOUCH_ENABLED

    config CYD_TOUCH_OFFSET_ROTATION
        int "CYD touch rotation offset"
        default 0
        range 0 7
        depends on CYD_TOUCH_ENABLED
        help
            Additional touch rotation/flip adjustment before calibration.

    config CYD_TOUCH_X_MIN
        int "CYD touch raw X min"
        default 300
        range 0 4095
        depends on CYD_TOUCH_ENABLED

    config CYD_TOUCH_X_MAX
        int "CYD touch raw X max"
        default 3900
        range 0 4095
        depends on CYD_TOUCH_ENABLED

    config CYD_TOUCH_Y_MIN
        int "CYD touch raw Y min"
        default 400
        range 0 4095
        depends on CYD_TOUCH_ENABLED

    config CYD_TOUCH_Y_MAX
        int "CYD touch raw Y max"
        default 3900
        range 0 4095
        depends on CYD_TOUCH_ENABLED

endmenu
