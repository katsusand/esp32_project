menu "ESP32 Wi-Fi STA"

    config ESP32_WIFI_STA_ENABLED
        bool "Enable ESP32 Wi-Fi station support"
        default n
        help
            Enables the project Wi-Fi STA component and optional app startup hook.

    config ESP32_WIFI_STA_AUTO_START
        bool "Start Wi-Fi STA during app startup"
        default n
        depends on ESP32_WIFI_STA_ENABLED
        help
            When enabled, app_main initializes and starts Wi-Fi STA after NVS
            initialization. Credentials are read from this Kconfig menu.

    config ESP32_WIFI_STA_WAIT_ON_BOOT
        bool "Wait for Wi-Fi connection during app startup"
        default n
        depends on ESP32_WIFI_STA_AUTO_START
        help
            If enabled, app_main waits for the configured timeout after starting
            Wi-Fi. A timeout is logged but does not stop the application.

    config ESP32_WIFI_STA_SCAN_LIST_SIZE
        int "Wi-Fi scan record count"
        default 30
        range 1 64
        depends on ESP32_WIFI_STA_ENABLED
        help
            Maximum number of AP records kept in RAM while Wi-Fi scan mode is active.

    config ESP32_WIFI_STA_SSID
        string "Wi-Fi SSID"
        default ""
        depends on ESP32_WIFI_STA_ENABLED
        help
            SSID used by the default Wi-Fi STA configuration.

    config ESP32_WIFI_STA_PASSWORD
        string "Wi-Fi password"
        default ""
        depends on ESP32_WIFI_STA_ENABLED
        help
            Password used by the default Wi-Fi STA configuration. Leave empty
            only for open networks.

    config ESP32_WIFI_STA_MAX_RETRY
        int "Wi-Fi connect retry count"
        default 5
        range 0 100
        depends on ESP32_WIFI_STA_ENABLED

    config ESP32_WIFI_STA_CONNECT_TIMEOUT_MS
        int "Wi-Fi boot wait timeout (ms)"
        default 15000
        range 100 120000
        depends on ESP32_WIFI_STA_ENABLED

    choice ESP32_WIFI_STA_SAE_MODE
        prompt "WPA3 SAE mode selection"
        default ESP32_WIFI_STA_WPA3_SAE_PWE_BOTH
        depends on ESP32_WIFI_STA_ENABLED
        help
            Select the SAE PWE derivation mode for WPA3-Personal networks.

        config ESP32_WIFI_STA_WPA3_SAE_PWE_HUNT_AND_PECK
            bool "HUNT AND PECK"

        config ESP32_WIFI_STA_WPA3_SAE_PWE_HASH_TO_ELEMENT
            bool "H2E"

        config ESP32_WIFI_STA_WPA3_SAE_PWE_BOTH
            bool "BOTH"
    endchoice

    config ESP32_WIFI_STA_SAE_H2E_IDENTIFIER
        string "WPA3 SAE H2E password identifier"
        default ""
        depends on ESP32_WIFI_STA_ENABLED && (ESP32_WIFI_STA_WPA3_SAE_PWE_HASH_TO_ELEMENT || ESP32_WIFI_STA_WPA3_SAE_PWE_BOTH)
        help
            Optional password identifier used with SAE Hash-to-Element.

    choice ESP32_WIFI_STA_SCAN_AUTH_MODE_THRESHOLD
        prompt "Wi-Fi scan auth mode threshold"
        default ESP32_WIFI_STA_AUTH_WPA2_PSK
        depends on ESP32_WIFI_STA_ENABLED
        help
            The weakest auth mode accepted during scan/connect.
            Select WEP/WPA only when connecting to deprecated networks.

        config ESP32_WIFI_STA_AUTH_OPEN
            bool "OPEN"

        config ESP32_WIFI_STA_AUTH_WEP
            bool "WEP"

        config ESP32_WIFI_STA_AUTH_WPA_PSK
            bool "WPA PSK"

        config ESP32_WIFI_STA_AUTH_WPA2_PSK
            bool "WPA2 PSK"

        config ESP32_WIFI_STA_AUTH_WPA_WPA2_PSK
            bool "WPA/WPA2 PSK"

        config ESP32_WIFI_STA_AUTH_WPA3_PSK
            bool "WPA3 PSK"

        config ESP32_WIFI_STA_AUTH_WPA2_WPA3_PSK
            bool "WPA2/WPA3 PSK"

        config ESP32_WIFI_STA_AUTH_WAPI_PSK
            bool "WAPI PSK"
    endchoice

endmenu
